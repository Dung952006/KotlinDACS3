<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0D0D1F">

    <!-- HEADER -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="✨ AI Assistant"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Hỏi về tài chính của bạn"
        android:textSize="13sp"
        android:textColor="#555577"

        android:layout_marginTop="2dp"
        android:layout_marginBottom="20dp"/>

    <!-- INPUT -->

    <EditText
        android:id="@+id/edtQuestion"

        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:hint="Nhập câu hỏi..."
        android:textColor="#FFFFFF"

        android:padding="14dp"

        android:background="@drawable/bg_ai_input"

        android:inputType="textMultiLine"
        android:minLines="2"/>

    <!-- SEND BUTTON -->

    <Button
        android:id="@+id/btnSend"

        android:layout_width="match_parent"
        android:layout_height="50dp"

        android:text="Gửi →"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="16sp"

        android:backgroundTint="#6C5CE7"

        android:layout_marginTop="12dp"/>

    <!-- PROGRESS -->

    <ProgressBar
        android:id="@+id/progressBar"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"

        android:indeterminateTint="#6C5CE7"/>

    <!-- RESPONSE AREA -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/txtResponse"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:text="Kết quả AI sẽ hiển thị ở đây"

            android:textColor="#A29BFE"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.5"

            android:padding="16dp"
            android:background="@drawable/bg_ai_response"/>

    </ScrollView>

</LinearLayout>
