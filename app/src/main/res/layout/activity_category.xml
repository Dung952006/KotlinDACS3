<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:orientation="vertical"
    android:background="#F0EEF9">

    <!-- BACK + TITLE ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="‹"
            android:textSize="28sp"
            android:textColor="#6C5CE7"
            android:gravity="center"
            android:background="@drawable/bg_back_btn"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Danh mục"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quản lý danh mục của bạn"
                android:textSize="13sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ADD FORM CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- CATEGORY NAME INPUT — giữ id cũ: edtCategoryName -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên danh mục"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#6B7280"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtCategoryName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="VD: Ăn uống"
                android:textSize="15sp"
                android:textColor="#1A1A2E"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="16dp"/>

            <!-- TYPE SPINNER — giữ id cũ: spinnerType -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#6B7280"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerType"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="16dp"/>

            <!-- ADD BUTTON — giữ id cũ: btnAddCategory -->
            <Button
                android:id="@+id/btnAddCategory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Thêm danh mục"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:backgroundTint="#6C5CE7"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- LIST TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Danh sách danh mục"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <!-- RECYCLER — giữ id cũ: recyclerCategories -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCategories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"/>

</LinearLayout>
