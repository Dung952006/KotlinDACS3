<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="#F0EEF9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <!-- BACK + TITLE ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="‹"
                android:textSize="28sp"
                android:textColor="#6C5CE7"
                android:gravity="center"
                android:background="@drawable/bg_back_btn"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="14dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sửa giao dịch"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cập nhật thông tin bên dưới"
                    android:textSize="13sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- CARD FORM -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- LABEL: TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiêu đề"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="8dp"/>

                <!-- TITLE INPUT -->
                <EditText
                    android:id="@+id/edtTitle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="VD: Tiền lương tháng 5"
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="20dp"/>

                <!-- LABEL: AMOUNT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số tiền (VND)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="8dp"/>

                <!-- AMOUNT INPUT -->
                <EditText
                    android:id="@+id/edtAmount"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="VD: 1000000"
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"
                    android:inputType="numberDecimal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="20dp"/>

                <!-- LABEL: CATEGORY -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Danh mục"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#6B7280"
                    android:layout_marginBottom="8dp"/>

                <!-- CATEGORY SPINNER -->
                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="28dp"/>

                <!-- UPDATE BUTTON -->
                <Button
                    android:id="@+id/btnUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Cập nhật"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:backgroundTint="#6C5CE7"
                    android:layout_marginBottom="12dp"/>

                <!-- DELETE BUTTON -->
                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Xóa giao dịch"
                    android:textAllCaps="false"
                    android:textColor="#FF647C"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:backgroundTint="#FFF0F2"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
