        <shape android:shape="rectangle">
            <solid android:color="#6C5CE7"/>
            <corners
                android:topLeftRadius="12dp"
                android:bottomLeftRadius="12dp"/>
            <size android:width="3dp"/>
        </shape>
    </item>

</layer-list>
